{
  "name": "benchwiki-api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:create": "wrangler d1 create benchwiki",
    "db:migrate": "wrangler d1 execute benchwiki --file=schema.sql",
    "db:migrate:remote": "wrangler d1 execute benchwiki --remote --file=schema.sql"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.0.0",
    "typescript": "^5.0.0",
    "wrangler": "^3.0.0"
  }
}
